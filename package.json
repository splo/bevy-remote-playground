{
  "name": "bevy-remote-playground",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "watch": "run-p watch:*",
    "prewatch": "npm run build:demo",
    "watch:web": "vite",
    "watch:demo": "chokidar \"demo/**/*.rs\" \"demo/Cargo.toml\" -c \"npm run build:demo\"",
    "build": "run-s build:demo build:web",
    "prebuild:demo": "cargo build --manifest-path demo/Cargo.toml --target wasm32-unknown-unknown --release",
    "build:demo": "wasm-bindgen --target web --out-dir public/wasm --out-name demo demo/target/wasm32-unknown-unknown/release/demo.wasm",
    "build:web": "vite build",
    "check": "run-p check:*",
    "check:types": "tsc -b",
    "check:lint": "eslint .",
    "lint": "run-p lint:*",
    "lint:fix": "eslint . --fix",
    "preview": "run-p preview:*",
    "prepreview": "npm run build",
    "preview:serve": "vite preview",
    "clean": "run-p clean:*",
    "clean:web": "rimraf dist",
    "clean:demo": "rimraf demo/target public/wasm"
  },
  "dependencies": {
    "@base-ui/react": "^1.2.0",
    "@codemirror/lang-javascript": "^6.2.5",
    "@codemirror/lang-json": "^6.0.2",
    "@codemirror/view": "^6.40.0",
    "@fontsource-variable/geist": "^5.2.8",
    "@tailwindcss/vite": "^4.2.1",
    "@uiw/react-codemirror": "^4.25.8",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.7.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-resizable-panels": "^4.7.1",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.1",
    "tw-animate-css": "^1.4.0",
    "usehooks-ts": "^3.1.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "chokidar-cli": "^3.0.0",
    "eslint": "^10.1.0",
    "eslint-plugin-react-hooks": "next",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "npm-run-all": "^4.1.5",
    "rimraf": "^6.1.3",
    "shadcn": "^4.0.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.48.0",
    "vite": "^8.0.3"
  }
}